## Public (safe to expose to the browser)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

## Server-only (NEVER public)
SUPABASE_SERVICE_ROLE_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

## Apple Music
# Note: Do NOT put an Apple *private key* in any PUBLIC_ env var.
# Apple Music support is intentionally disabled in the UI for now.
